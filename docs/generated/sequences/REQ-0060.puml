@startuml REQ-0060_Device_Provisioning
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

entity "User Action" as User_Action
entity "External" as External

box "System" #LightBlue
  participant "Provisioning Manager" as Provisioning_Manager
  participant "WiFi Scanner" as WiFi_Scanner
  participant "Cert Manager" as Cert_Manager
  participant "Event Bus" as Event_Bus
  participant "Comm Manager" as Comm_Manager
end box

header
  **REQ-0060: Device Provisioning**
  //Description:// Orchestrate device provisioning: scan networks, join, and\ninstall certificates.
  //Acceptance Criteria:// Device progresses through scan/join/cert states.\nProvisioning completes or retries on failure.
end header


User_Action --> Provisioning_Manager: EVENT_FACTORY_RESET_COMPLETE\nProvision_Start()
activate Provisioning_Manager
External --> Provisioning_Manager: EVENT_PROV_SCAN_COMPLETE\nProvision_OnScanComplete()
WiFi_Scanner --> Provisioning_Manager: EVENT_PROV_JOIN_RESULT\nProvision_OnJoinResult()
Cert_Manager --> Provisioning_Manager: EVENT_PROV_CERT_INSTALLED\nProvision_OnCertInstalled()
== Provision_Init() ==
Provisioning_Manager -> Event_Bus: Event_register(EVENT_FACTORY_RESET_COMPLETE, Provision_Start)
activate Event_Bus
Event_Bus <-- Provisioning_Manager: return
deactivate Event_Bus
Provisioning_Manager -> Event_Bus: Event_register(EVENT_PROV_SCAN_COMPLETE, Provision_OnScanComplete)
activate Event_Bus
Event_Bus <-- Provisioning_Manager: return
deactivate Event_Bus
Provisioning_Manager -> Event_Bus: Event_register(EVENT_PROV_JOIN_RESULT, Provision_OnJoinResult)
activate Event_Bus
Event_Bus <-- Provisioning_Manager: return
deactivate Event_Bus
Provisioning_Manager -> Event_Bus: Event_register(EVENT_PROV_CERT_INSTALLED, Provision_OnCertInstalled)
activate Event_Bus
Event_Bus <-- Provisioning_Manager: return
deactivate Event_Bus
== Provision_Start() ==
note right of Provisioning_Manager: Prov State Init
Provisioning_Manager --> WiFi_Scanner: EVENT_PROV_SCAN_START\nProvision_Start() -> WiFiScan_Start()
== Provision_OnScanComplete() ==
alt count > 0
Provisioning_Manager --> WiFi_Scanner: EVENT_PROV_JOIN_REQUEST\nProvision_OnScanComplete() -> WiFiScan_Join()
WiFi_Scanner --> Provisioning_Manager: EVENT_PROV_JOIN_RESULT\nWiFiScan_Join() -> Provision_OnJoinResult()
note right of Provisioning_Manager: Prov Retry Check
alt result->success
Provisioning_Manager --> Cert_Manager: EVENT_PROV_CERT_REQUEST\nProvision_OnJoinResult() -> Cert_Provision()
else
alt retry_count < MAX_RETRIES
Provisioning_Manager --> WiFi_Scanner: EVENT_PROV_SCAN_START\nProvision_OnJoinResult() -> WiFiScan_Start()
end alt
end alt
else
Provisioning_Manager --> Provisioning_Manager: EVENT_PROV_FAILED
end alt
== Provision_OnCertInstalled() ==
note right of Provisioning_Manager: Prov State Ready
Provisioning_Manager -> Comm_Manager: Comm_SendStatus(&prov_status)
activate Comm_Manager
Comm_Manager <-- Provisioning_Manager: return
deactivate Comm_Manager
Provisioning_Manager --> Provisioning_Manager: EVENT_PROV_COMPLETE
deactivate Provisioning_Manager

@enduml