@startuml REQ-0062_Certificate_Provisioning
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

actor "User" as User
entity "Mobile" as Mobile

box "IoT Library" #LightBlue
  participant "Provisioning Manager" as Provisioning_Manager
  participant "Cert Manager" as Cert_Manager
  participant "Event Bus" as Event_Bus
end box

header
  **REQ-0062: Certificate Provisioning**
  //Description:// Fetch and install device certificate from provisioning\nserver.
  //Acceptance Criteria:// Certificate downloaded via HTTPS and written to flash.
end header


Provisioning_Manager --> Cert_Manager: EVENT_PROV_CERT_REQUEST
activate Cert_Manager
== Cert_Provision() ==
Cert_Manager --> Provisioning_Manager: EVENT_PROV_CERT_INSTALLED
== Cert_Init() ==
Cert_Manager -> Event_Bus: Event_register(EVENT_PROV_CERT_REQUEST, Cert_Provision)
activate Event_Bus
deactivate Cert_Manager
deactivate Event_Bus

@enduml