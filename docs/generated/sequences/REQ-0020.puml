@startuml REQ-0020 Remote Status Reporting
autonumber

entity "WiFi Stack" as WiFi_Stack
entity "Cloud" as Cloud

box "System" #LightBlue
  participant "Comm Manager" as Comm_Manager
  participant "Event Bus" as Event_Bus
end box

header
  **REQ-0020: Remote Status Reporting**
  //Description:// Publish device status to cloud via MQTT and handle shadow sync
  //Acceptance Criteria:// Comm_SendStatus publishes to MQTT; shadow events update connectivity state
  //Preconditions:// REQ-0030 (Control Loop Processing)
end header


WiFi_Stack -> Comm_Manager: EVENT:WIFI_DISCONNECTED
WiFi_Stack -> Comm_Manager: EVENT:WIFI_CONNECTED
WiFi_Stack -> Comm_Manager: EVENT:MQTT_CONNACK
WiFi_Stack -> Comm_Manager: EVENT:MQTT_CLOSE
Comm_Manager -> Event_Bus: Event_register()
Comm_Manager --> Cloud: EVENT:CLOUD_CONFIG_UPDATE\nShadow_ScheduleConfigPublish()

@enduml