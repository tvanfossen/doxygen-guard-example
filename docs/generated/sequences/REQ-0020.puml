@startuml REQ-0020 Remote Status Reporting
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

entity "WiFi Stack" as WiFi_Stack

box "System" #LightBlue
  participant "Comm Manager" as Comm_Manager
end box

header
  **REQ-0020: Remote Status Reporting**
  //Description:// Publish device status to cloud via MQTT transport. Handle\nshadow state synchronization events.
  //Acceptance Criteria:// Comm_SendStatus publishes to MQTT topic. Shadow connectivity\nevents update local state.
  //Preconditions:// REQ-0030 (Control Loop Processing)
end header

note over Comm_Manager: Comm_Init()
note over Comm_Manager: Shadow_Initialize()

alt EVENT_WIFI_DISCONNECTED
WiFi_Stack --> Comm_Manager: EVENT_WIFI_DISCONNECTED\nShadow_OnConnectivityEvent()
activate Comm_Manager
else [EVENT_WIFI_CONNECTED]
WiFi_Stack --> Comm_Manager: EVENT_WIFI_CONNECTED\nShadow_OnConnectivityEvent()
else [EVENT_MQTT_CONNACK]
WiFi_Stack --> Comm_Manager: EVENT_MQTT_CONNACK\nShadow_OnConnectivityEvent()
else [EVENT_MQTT_CLOSE]
WiFi_Stack --> Comm_Manager: EVENT_MQTT_CLOSE\nShadow_OnConnectivityEvent()
end alt
== Comm_SendStatus() ==
Comm_Manager --> Comm_Manager: EVENT_COMM_TX_COMPLETE
deactivate Comm_Manager

@enduml