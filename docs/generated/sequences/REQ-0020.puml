@startuml REQ-0020_Remote_Status_Reporting
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

actor "User" as User
entity "Mobile" as Mobile
entity "WiFi Stack" as WiFi_Stack

box "IoT Library" #LightBlue
  participant "Comm Manager" as Comm_Manager
  participant "Event Bus" as Event_Bus
end box

header
  **REQ-0020: Remote Status Reporting**
  //Description:// Publish device status to cloud via MQTT transport. Handle\nshadow state synchronization events.
  //Acceptance Criteria:// Comm_SendStatus publishes to MQTT topic. Shadow connectivity\nevents update local state.
  //Preconditions:// REQ-0030 (Control Loop Processing)
end header


WiFi_Stack --> Comm_Manager: EVENT_WIFI_DISCONNECTED
activate Comm_Manager
WiFi_Stack --> Comm_Manager: EVENT_WIFI_CONNECTED
WiFi_Stack --> Comm_Manager: EVENT_MQTT_CONNACK
WiFi_Stack --> Comm_Manager: EVENT_MQTT_CLOSE
== Comm_Init() ==
Comm_Manager -> Event_Bus: Event_register(EVENT_COMM_RX_RECEIVED, Comm_OnRemoteCommand)
activate Event_Bus
Comm_Manager -> Event_Bus: Event_register(EVENT_COMM_DOWNLOAD_START, Comm_DownloadFirmware)
== Comm_SendStatus() ==
Comm_Manager --> Comm_Manager: EVENT_COMM_TX_COMPLETE
== Shadow_Initialize() ==
Comm_Manager -> Event_Bus: Event_register(EVENT_WIFI_DISCONNECTED | EVENT_WIFI_CONNECTED |
        EVENT_MQTT_CONNACK | EVENT_MQTT_CLOSE, Shadow_OnConnectivityEvent)
deactivate Comm_Manager
deactivate Event_Bus

@enduml