@startuml REQ-0101_Device_Setting_Change
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

actor "User" as User
entity "Mobile" as Mobile
entity "Cloud" as Cloud
entity "MCU" as MCU

box "IoT Library" #LightBlue
  participant "IoT Library" as IoT_Library
end box

header
  **REQ-0101: Device Setting Change**
  //Description:// Receive shadow delta for device settings, apply to MCU\nconfiguration, and report updated state to cloud.
  //Acceptance Criteria:// Setting applied to MCU via DCI callback. Updated setting\npublished to shadow/reported.
end header


alt strcmp(key, "fanpower") == 0
IoT_Library --> IoT_Library: EVENT_SETTING_CHANGE
end alt
== send_cmd_response() ==
IoT_Library -> Cloud: CloudMgr_Publish("cmd/resp", &resp, sizeof(resp))
activate Cloud
== apply_setting() ==
IoT_Library -> MCU: DurableEventCb(DURABLE_IN_EVENT_CONFIG, &update)
activate MCU
IoT_Library -> Cloud: CloudMgr_Publish("shadow/reported", &update, sizeof(update))
deactivate Cloud
deactivate MCU

@enduml