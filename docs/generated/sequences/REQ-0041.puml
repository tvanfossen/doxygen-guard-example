@startuml REQ-0041 OTA Download Coordination
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

entity "Hardware" as Hardware
entity "Cloud" as Cloud

box "System" #LightBlue
  participant "OTA Manager" as OTA_Manager
  participant "Comm Manager" as Comm_Manager
  participant "Event Bus" as Event_Bus
end box

header
  **REQ-0041: OTA Download Coordination**
  //Description:// Stream firmware chunks from HTTP server and post\nchunk-received events for OTA manager processing.
  //Acceptance Criteria:// Comm_DownloadFirmware streams chunks and posts completion\nevent.
end header


OTA_Manager --> Comm_Manager: EVENT_COMM_DOWNLOAD_START\nComm_DownloadFirmware()
activate Comm_Manager
== Comm_Init() ==
Comm_Manager -> Event_Bus: Event_register(EVENT_COMM_RX_RECEIVED, Comm_OnRemoteCommand)
activate Event_Bus
Event_Bus <-- Comm_Manager: return
deactivate Event_Bus
Comm_Manager -> Event_Bus: Event_register(EVENT_COMM_DOWNLOAD_START, Comm_DownloadFirmware)
activate Event_Bus
Event_Bus <-- Comm_Manager: return
deactivate Event_Bus
== Comm_DownloadFirmware() ==
loop http_has_data(&stream)
Comm_Manager --> OTA_Manager: EVENT_COMM_CHUNK_RECEIVED\nComm_DownloadFirmware() -> OTA_OnChunkReceived()
OTA_Manager --> Hardware: EVENT_HW_FLASH_WRITE\nOTA_OnChunkReceived()
end loop
Comm_Manager --> OTA_Manager: EVENT_COMM_DOWNLOAD_COMPLETE\nComm_DownloadFirmware() -> OTA_OnDownloadComplete()
note right of OTA_Manager: Ota Verify Crc
OTA_Manager -> Comm_Manager: Comm_SendStatus(&status)
Comm_Manager <-- OTA_Manager: return
deactivate Comm_Manager
OTA_Manager --> Cloud: EVENT_CLOUD_OTA_RESULT\nOTA_OnDownloadComplete()

@enduml