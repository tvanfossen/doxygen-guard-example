@startuml REQ-0021 Remote Command Handling
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

entity "External" as External

box "System" #LightBlue
  participant "Comm Manager" as Comm_Manager
  participant "Controller" as Controller
end box

header
  **REQ-0021: Remote Command Handling**
  //Description:// Receive and dispatch remote commands from cloud. Parse\ncommand payload and post control action events.
  //Acceptance Criteria:// Comm_OnRemoteCommand parses command and posts\nEVENT:CONTROL_ACTION.
end header


External --> Comm_Manager: EVENT:COMM_RX_RECEIVED\nComm_OnRemoteCommand()
activate Comm_Manager
== Comm_OnRemoteCommand() ==
Comm_Manager --> Controller: EVENT:CONTROL_ACTION\nComm_OnRemoteCommand() -> Controller_ReportStatus()
Controller -> Comm_Manager: Comm_SendStatus()
Comm_Manager --> Controller: return
deactivate Comm_Manager

@enduml