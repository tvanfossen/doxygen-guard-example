@startuml REQ-0102_Dock_Command
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

actor "User" as User
entity "Mobile" as Mobile
entity "Cloud" as Cloud
entity "MCU" as MCU

box "IoT Library" #LightBlue
  participant "IoT Library" as IoT_Library
end box

header
  **REQ-0102: Dock Command**
  //Description:// Receive cloud dock command via MQTT and send return-to-base\ninstruction to MCU.
  //Acceptance Criteria:// Dock command dispatched to MCU via DCI callback. Product\nstatus published during return.
end header


User -> Mobile: Dock Command
activate Mobile
Mobile -> Cloud: Dock Command
activate Cloud
Cloud --> IoT_Library: cmd/req
activate IoT_Library
== execute_dock() ==
IoT_Library -> MCU: DurableEventCb(DURABLE_IN_EVENT_DOCK, NULL)
activate MCU
loop "as product status changes"
MCU --> IoT_Library: product_status
== on_product_status() ==
IoT_Library -> Cloud:  shadow/reported
end loop
deactivate Cloud
deactivate IoT_Library
deactivate MCU
deactivate Mobile

@enduml