@startuml REQ-PROD-002_Remote_Device_Control
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

actor "User" as User
entity "Mobile" as Mobile
entity "External" as External

box "IoT Library" #LightBlue
  participant "Comm Manager" as Comm_Manager
  participant "Controller" as Controller
end box

header
  **REQ-PROD-002: Remote Device Control**
  //Description:// The system shall accept remote commands from cloud and\nexecute control actions.
  //Acceptance Criteria:// Cloud command received within 30s. Control action executed\nand status reported back.
end header


External --> Comm_Manager: EVENT_COMM_RX_RECEIVED
activate Comm_Manager
External --> Controller: Controller_ReportStatus()
activate Controller
== Comm_OnRemoteCommand() ==
Comm_Manager --> Controller: EVENT_CONTROL_ACTION
Controller -> Comm_Manager: Comm_SendStatus(&status)
deactivate Comm_Manager
deactivate Controller

@enduml