@startuml REQ-0061_WiFi_Network_Discovery
autonumber
skinparam maxMessageSize 200
skinparam responseMessageBelowArrow true

actor "User" as User
entity "Mobile" as Mobile

box "IoT Library" #LightBlue
  participant "Provisioning Manager" as Provisioning_Manager
  participant "WiFi Scanner" as WiFi_Scanner
  participant "Event Bus" as Event_Bus
end box

header
  **REQ-0061: WiFi Network Discovery**
  //Description:// Scan for available networks and attempt association.
  //Acceptance Criteria:// Scan returns network list. Join produces success or failure\nresult.
end header


Provisioning_Manager --> WiFi_Scanner: EVENT_PROV_SCAN_START
activate WiFi_Scanner
Provisioning_Manager --> WiFi_Scanner: EVENT_PROV_JOIN_REQUEST
== WiFiScan_Join() ==
WiFi_Scanner --> Provisioning_Manager: EVENT_PROV_JOIN_RESULT
== WiFiScan_Init() ==
WiFi_Scanner -> Event_Bus: Event_register(EVENT_PROV_SCAN_START, WiFiScan_Start)
activate Event_Bus
WiFi_Scanner -> Event_Bus: Event_register(EVENT_PROV_JOIN_REQUEST, WiFiScan_Join)
deactivate Event_Bus
deactivate WiFi_Scanner

@enduml